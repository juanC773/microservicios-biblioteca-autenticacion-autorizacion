    {
      "name": "54 - Circulación GET /prestamos (capture prestamoId libroId=1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});",
              "if (pm.response.code !== 200) { return; }",
              "let prestamos;",
              "try { prestamos = pm.response.json(); } catch (e) { return; }",
              "const match = Array.isArray(prestamos) ? prestamos.find(p => p && p.libroId && (p.libroId.libroid_value || p.libroId) === '1' && p.estado === 'ACTIVO') : null;",
              "pm.test('found prestamo ACTIVO for libroId=1', function () {",
              "  pm.expect(match).to.be.ok;",
              "});",
              "if (match && match.id) {",
              "  const pid = match.id.prestamoid_value != null ? match.id.prestamoid_value : (typeof match.id === 'string' ? match.id : null);",
              "  if (pid) pm.collectionVariables.set('prestamo_id_book1', pid);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token_librarian}}" }],
        "url": {
