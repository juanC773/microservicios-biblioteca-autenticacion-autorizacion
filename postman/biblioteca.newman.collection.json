  "item": [
    {
      "name": "00 - Admin token (master realm)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('kc_admin_token', json.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "admin-cli", "type": "text" },
            { "key": "username", "value": "{{kc_admin_user}}", "type": "text" },
            { "key": "password", "value": "{{kc_admin_pass}}", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{kc_base}}/realms/master/protocol/openid-connect/token",
          "host": ["{{kc_base}}"],
          "path": ["realms", "master", "protocol", "openid-connect", "token"]
        }
      }
    },
    {
      "name": "01 - Find test user (biblioteca realm)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});",
              "const users = pm.response.json();",
              "if (Array.isArray(users) && users.length > 0) {",
              "  pm.collectionVariables.set('test_user_id', users[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{kc_admin_token}}" }
        ],
        "url": {
          "raw": "{{kc_base}}/admin/realms/{{kc_realm}}/users?username={{test_user}}",
          "host": ["{{kc_base}}"],
          "path": ["admin", "realms", "{{kc_realm}}", "users"],
          "query": [{ "key": "username", "value": "{{test_user}}" }]
